{
  "name": "scbs",
  "private": true,
  "version": "0.1.0",
  "description": "Shared Context Build System monorepo",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "bun run --cwd apps/cli build",
    "ci": "bun run verify:ci",
    "lint": "biome check .",
    "test": "bun test",
    "test:packages": "bun scripts/run-package-checks.ts test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "bun scripts/run-verification.ts local",
    "verify:ci": "bun scripts/run-verification.ts ci",
    "verify:migrations": "bun scripts/verify-postgres.ts",
    "verify:openapi": "bun scripts/verify-openapi.ts",
    "verify:postgres": "bun scripts/verify-postgres.ts",
    "cli": "bun run --cwd apps/cli dev --"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "24.3.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
